# Environment file for the HTTP Server Manager systemd service.
#
# Install it (owner-readable only, since it holds a secret):
#   sudo install -m600 http-server-manager.env.example /etc/http-server-manager.env
#   sudo nano /etc/http-server-manager.env
# then reference it from the unit (already wired via EnvironmentFile).

# REQUIRED before exposing the manager to any network (Tailscale, LAN, etc.).
# Anyone who has this token can start programs and clone-and-run repos on this
# machine, so treat it like a password. Generate a strong one, e.g.:
#   openssl rand -hex 32
MANAGER_API_TOKEN=change-me-to-a-long-random-string

# Optional: bind address. With a token set, the manager binds 0.0.0.0 by default
# so Tailscale/LAN can reach it. To restrict it to the Tailscale interface only,
# set this to your Tailscale IP (100.x.y.z).
# MANAGER_HOST=0.0.0.0

# Optional: Tailscale MagicDNS hostname for HTTPS program URLs, if the tailscale
# CLI isn't available to the manager.
# TAILSCALE_HOSTNAME=my-host.my-tailnet.ts.net
